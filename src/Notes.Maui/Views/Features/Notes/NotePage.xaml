<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:Notes.Maui.ViewModels.Features.Notes"
             x:Class="Notes.Maui.Views.Features.Notes.NotePage"
             x:DataType="viewmodels:NoteViewModel"
             AutomationId="PageTitle"
             Title="{Binding Title}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Text="Save"
                     AutomationId="SaveButton"
                     Command="{Binding SaveNoteCommand}">
            <ToolbarItem.IconImageSource>
                <FontImageSource Glyph="&#xe5ca;" FontFamily="MaterialIcons" Size="24"
                                 Color="{AppThemeBinding Light={StaticResource Black}, Dark={StaticResource White}}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="*,Auto">

        <!-- Writing surface: full-bleed with note color -->
        <Grid Grid.Row="0"
              RowDefinitions="Auto,Auto,*"
              Padding="20,12,20,16"
              BackgroundColor="{Binding Note.BackgroundColor, FallbackValue='#FFFFFF'}">

            <!-- Title -->
            <Editor Grid.Row="0"
                    x:Name="TitleEditor"
                    AutomationId="NoteTitleEditor"
                    Placeholder="Title"
                    Text="{Binding Note.Title, FallbackValue=''}"
                    FontFamily="PlusJakartaSansBold"
                    FontSize="26"
                    HeightRequest="56"
                    MaxLength="200"
                    BackgroundColor="Transparent"
                    TextColor="#1A1A1A"
                    PlaceholderColor="#BDBDBD" />

            <!-- Title / body separator -->
            <BoxView Grid.Row="1"
                     HeightRequest="1"
                     BackgroundColor="#E0E0E0"
                     Margin="0,0,0,12" />

            <!-- Body -->
            <Editor Grid.Row="2"
                    x:Name="TextEditor"
                    AutomationId="NoteEditor"
                    Placeholder="Write something..."
                    Text="{Binding Note.Text}"
                    FontSize="16"
                    BackgroundColor="Transparent"
                    TextColor="#333333"
                    PlaceholderColor="#BDBDBD" />

        </Grid>

        <!-- Bottom toolbar: fixed white background, always readable -->
        <Frame Grid.Row="1"
               HasShadow="False"
               CornerRadius="0"
               Padding="20,10,20,12"
               BorderColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray600}}"
               BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

            <Grid ColumnDefinitions="Auto,*">

                <!-- Last updated -->
                <StackLayout Grid.Column="0"
                             Orientation="Horizontal"
                             VerticalOptions="Center"
                             Spacing="4">
                    <Label Text="&#xe923;"
                           FontFamily="MaterialIcons"
                           FontSize="13"
                           TextColor="#BDBDBD"
                           VerticalOptions="Center" />
                    <Label Text="{Binding Note.UpdatedAt, StringFormat='{0:MMM d, yyyy}'}"
                           FontSize="12"
                           TextColor="#BDBDBD"
                           VerticalOptions="Center" />
                </StackLayout>

                <!-- Color picker -->
                <ScrollView Grid.Column="1"
                            Orientation="Horizontal"
                            HorizontalScrollBarVisibility="Never"
                            VerticalOptions="Center">
                    <HorizontalStackLayout Spacing="8" Padding="12,0,4,0" HorizontalOptions="End">

                        <Button BackgroundColor="#FFFFFF" WidthRequest="28" HeightRequest="28" CornerRadius="14"
                                BorderWidth="1.5" BorderColor="#DADADA"
                                Command="{Binding SetBackgroundColorCommand}" CommandParameter="#FFFFFF">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding Note.BackgroundColor}" Value="#FFFFFF">
                                    <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                                    <Setter Property="BorderWidth" Value="2.5" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                        <Button BackgroundColor="#FFE0E0" WidthRequest="28" HeightRequest="28" CornerRadius="14"
                                BorderWidth="1.5" BorderColor="Transparent"
                                Command="{Binding SetBackgroundColorCommand}" CommandParameter="#FFE0E0">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding Note.BackgroundColor}" Value="#FFE0E0">
                                    <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                                    <Setter Property="BorderWidth" Value="2.5" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                        <Button BackgroundColor="#FFE6F2" WidthRequest="28" HeightRequest="28" CornerRadius="14"
                                BorderWidth="1.5" BorderColor="Transparent"
                                Command="{Binding SetBackgroundColorCommand}" CommandParameter="#FFE6F2">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding Note.BackgroundColor}" Value="#FFE6F2">
                                    <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                                    <Setter Property="BorderWidth" Value="2.5" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                        <Button BackgroundColor="#FFEAD6" WidthRequest="28" HeightRequest="28" CornerRadius="14"
                                BorderWidth="1.5" BorderColor="Transparent"
                                Command="{Binding SetBackgroundColorCommand}" CommandParameter="#FFEAD6">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding Note.BackgroundColor}" Value="#FFEAD6">
                                    <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                                    <Setter Property="BorderWidth" Value="2.5" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                        <Button BackgroundColor="#FFF4CC" WidthRequest="28" HeightRequest="28" CornerRadius="14"
                                BorderWidth="1.5" BorderColor="Transparent"
                                Command="{Binding SetBackgroundColorCommand}" CommandParameter="#FFF4CC">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding Note.BackgroundColor}" Value="#FFF4CC">
                                    <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                                    <Setter Property="BorderWidth" Value="2.5" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                        <Button BackgroundColor="#E0FFE0" WidthRequest="28" HeightRequest="28" CornerRadius="14"
                                BorderWidth="1.5" BorderColor="Transparent"
                                Command="{Binding SetBackgroundColorCommand}" CommandParameter="#E0FFE0">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding Note.BackgroundColor}" Value="#E0FFE0">
                                    <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                                    <Setter Property="BorderWidth" Value="2.5" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                        <Button BackgroundColor="#D9FFF5" WidthRequest="28" HeightRequest="28" CornerRadius="14"
                                BorderWidth="1.5" BorderColor="Transparent"
                                Command="{Binding SetBackgroundColorCommand}" CommandParameter="#D9FFF5">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding Note.BackgroundColor}" Value="#D9FFF5">
                                    <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                                    <Setter Property="BorderWidth" Value="2.5" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                        <Button BackgroundColor="#E0F7FF" WidthRequest="28" HeightRequest="28" CornerRadius="14"
                                BorderWidth="1.5" BorderColor="Transparent"
                                Command="{Binding SetBackgroundColorCommand}" CommandParameter="#E0F7FF">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding Note.BackgroundColor}" Value="#E0F7FF">
                                    <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                                    <Setter Property="BorderWidth" Value="2.5" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                        <Button BackgroundColor="#E0F0FF" WidthRequest="28" HeightRequest="28" CornerRadius="14"
                                BorderWidth="1.5" BorderColor="Transparent"
                                Command="{Binding SetBackgroundColorCommand}" CommandParameter="#E0F0FF">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding Note.BackgroundColor}" Value="#E0F0FF">
                                    <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                                    <Setter Property="BorderWidth" Value="2.5" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                        <Button BackgroundColor="#EDE0FF" WidthRequest="28" HeightRequest="28" CornerRadius="14"
                                BorderWidth="1.5" BorderColor="Transparent"
                                Command="{Binding SetBackgroundColorCommand}" CommandParameter="#EDE0FF">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding Note.BackgroundColor}" Value="#EDE0FF">
                                    <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                                    <Setter Property="BorderWidth" Value="2.5" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                        <Button BackgroundColor="#F5E8FF" WidthRequest="28" HeightRequest="28" CornerRadius="14"
                                BorderWidth="1.5" BorderColor="Transparent"
                                Command="{Binding SetBackgroundColorCommand}" CommandParameter="#F5E8FF">
                            <Button.Triggers>
                                <DataTrigger TargetType="Button" Binding="{Binding Note.BackgroundColor}" Value="#F5E8FF">
                                    <Setter Property="BorderColor" Value="{StaticResource Primary}" />
                                    <Setter Property="BorderWidth" Value="2.5" />
                                </DataTrigger>
                            </Button.Triggers>
                        </Button>

                    </HorizontalStackLayout>
                </ScrollView>
            </Grid>
        </Frame>

    </Grid>
</ContentPage>
